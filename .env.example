# Environment variables for GLOWdex
# Copy this file to .env.local to use

# Mapbox Token (Required for Map)
# Get one at https://account.mapbox.com/
# Recommended: Restrict this token to your specific domains/URLs
VITE_MAPBOX_TOKEN=

# PostHog Analytics
VITE_PUBLIC_POSTHOG_KEY=your_project_api_key
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
VITE_PUBLIC_POSTHOG_ENABLED=false

# API Configuration
# Base URL for the backend API.
# In development, this is typically handled by the Vite proxy (/api -> localhost:8080).
VITE_API_BASE_URL=/api

# Timeout for API requests in milliseconds (default: 30000).
VITE_API_TIMEOUT_MS=30000

# API key for backend authentication (required)
# CAUTION: VITE_ variables are bundled into client-side JS and visible in browser.
# This key provides basic protection against casual abuse, not true security.
# For sensitive APIs, consider: server-side proxy (BFF), OAuth/session-based auth,
# or keeping sensitive operations on authenticated-only endpoints.
VITE_API_KEY=
