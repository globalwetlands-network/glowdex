# Environment variables for GLOWdex
# Copy this file to .env.local to use

# Mapbox Token (Required for Map)
# Get one at https://account.mapbox.com/
# Recommended: Restrict this token to your specific domains/URLs
VITE_MAPBOX_TOKEN=

# PostHog Analytics
# VITE_PUBLIC_POSTHOG_KEY=your_project_api_key
# VITE_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# VITE_PUBLIC_POSTHOG_ENABLED=true
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
VITE_PUBLIC_POSTHOG_ENABLED=true
